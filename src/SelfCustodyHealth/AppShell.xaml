<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SelfCustodyHealth.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Self-Custody Health"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid
                x:Name="FlyoutItemLayout"
                Padding="20,0"
                HeightRequest="50">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter
                                        TargetName="FlyoutItemLayout"
                                        Property="Grid.BackgroundColor"
                                        Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
                                    <Setter
                                        TargetName="FlyoutItemLabel"
                                        Property="Label.TextColor"
                                        Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter
                                        TargetName="FlyoutItemLayout"
                                        Property="Grid.BackgroundColor"
                                        Value="{AppThemeBinding Light={StaticResource AppPrimarySoft}, Dark={StaticResource AppPrimarySoftDark}}" />
                                    <Setter
                                        TargetName="FlyoutItemLabel"
                                        Property="Label.TextColor"
                                        Value="{StaticResource AppPrimary}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Label
                    x:Name="FlyoutItemLabel"
                    FontAttributes="Bold"
                    FontSize="14"
                    Text="{Binding Title}"
                    VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.MenuItemTemplate>
        <DataTemplate>
            <Grid
                Padding="20,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}"
                HeightRequest="50">
                <Label
                    FontAttributes="Bold"
                    FontSize="14"
                    Text="{Binding Text}"
                    TextColor="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}"
                    VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.MenuItemTemplate>
</Shell>
