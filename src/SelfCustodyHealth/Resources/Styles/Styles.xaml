<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Thickness x:Key="PagePadding">20,18,20,24</Thickness>
    <Thickness x:Key="CardPadding">18</Thickness>
    <x:Double x:Key="CardCornerRadius">20</x:Double>
    <x:Double x:Key="SectionSpacing">14</x:Double>

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppPageBackgroundLight}, Dark={StaticResource AppPageBackgroundDark}}" />
    </Style>

    <Style TargetType="Shell">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppPageBackgroundDark}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
        <Setter Property="Shell.FlyoutBackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="TabBar">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppPageBackgroundDark}}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
        <Setter Property="Shell.FlyoutBackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
    </Style>

    <Style
        TargetType="Label"
        Class="FlyoutItemLabelStyle">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
    </Style>

    <Style
        TargetType="Layout"
        Class="FlyoutItemLayoutStyle"
        ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
    </Style>

    <Style x:Key="PageTitleLabel" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="SemanticProperties.HeadingLevel" Value="Level1" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
    </Style>

    <Style x:Key="SectionTitleLabel" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="SemanticProperties.HeadingLevel" Value="Level2" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
    </Style>

    <Style x:Key="BodyTextLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextSecondaryLight}, Dark={StaticResource AppTextSecondaryDark}}" />
    </Style>

    <Style x:Key="MutedTextLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
    </Style>

    <Style x:Key="MetricValueLabel" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="BackgroundColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="TextColor" Value="{StaticResource AppOnPrimaryText}" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppPrimarySoft}, Dark={StaticResource AppElevatedSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppPrimary}, Dark={StaticResource AppTextPrimaryDark}}" />
    </Style>

    <Style x:Key="DestructiveSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="TextColor" Value="{StaticResource AppDanger}" />
    </Style>

    <Style x:Key="HealthCardBorder" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppElevatedSurfaceLight}, Dark={StaticResource AppElevatedSurfaceDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource AppStrokeLight}, Dark={StaticResource AppStrokeDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
    </Style>

    <Style x:Key="StatusBadgeBorder" TargetType="Border">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppPrimarySoft}, Dark={StaticResource AppSurfaceDark}}" />
    </Style>

    <Style x:Key="SoftContainerBorder" TargetType="Border">
        <Setter Property="Padding" Value="14" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppPrimarySoft}, Dark={StaticResource AppPrimarySoftDark}}" />
    </Style>

    <Style x:Key="DocumentRowBorder" TargetType="Border">
        <Setter Property="Padding" Value="14" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource AppStrokeLight}, Dark={StaticResource AppStrokeDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppElevatedSurfaceLight}, Dark={StaticResource AppElevatedSurfaceDark}}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CancelButtonColor" Value="{StaticResource AppPrimary}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimaryLight}, Dark={StaticResource AppTextPrimaryDark}}" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource AppTextMutedLight}, Dark={StaticResource AppTextMutedDark}}" />
    </Style>
</ResourceDictionary>
